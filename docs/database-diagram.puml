@startuml
title ElectroCorp - Database Diagram

hide circle
skinparam linetype ortho
skinparam shadowing false
skinparam class {
    BackgroundColor #FFFFFF
    BorderColor #333333
    ArrowColor #333333
}

entity "user" as user {
    * id : BIGINT <<PK>>
    --
    full_name : VARCHAR(120)
    email : VARCHAR(120) <<UNIQUE>>
    password_hash : VARCHAR(255)
    status : VARCHAR(20)
    created_at : DATETIME
    updated_at : DATETIME
}

entity "access_profile" as access_profile {
    * id : BIGINT <<PK>>
    --
    name : VARCHAR(50) <<UNIQUE>>
    description : VARCHAR(255)
    created_at : DATETIME
    updated_at : DATETIME
}

entity "permission" as permission {
    * id : BIGINT <<PK>>
    --
    code : VARCHAR(80) <<UNIQUE>>
    description : VARCHAR(255)
}

entity "user_access_profile" as user_access_profile {
    * id : BIGINT <<PK>>
    --
    user_id : BIGINT <<FK>>
    access_profile_id : BIGINT <<FK>>
    assigned_at : DATETIME
}

entity "access_profile_permission" as access_profile_permission {
    * id : BIGINT <<PK>>
    --
    access_profile_id : BIGINT <<FK>>
    permission_id : BIGINT <<FK>>
}

entity "device" as device {
    * id : BIGINT <<PK>>
    --
    user_id : BIGINT <<FK>>
    name : VARCHAR(120)
    room : VARCHAR(80)
    type : VARCHAR(40)
    status : VARCHAR(20)
    power_watts : DECIMAL(10,2)
    created_at : DATETIME
    updated_at : DATETIME
}

entity "routine" as routine {
    * id : BIGINT <<PK>>
    --
    user_id : BIGINT <<FK>>
    device_id : BIGINT <<FK>>
    name : VARCHAR(120)
    action : VARCHAR(40)
    scheduled_time : TIME
    enabled : BOOLEAN
    created_at : DATETIME
    updated_at : DATETIME
}

entity "energy_reading" as energy_reading {
    * id : BIGINT <<PK>>
    --
    device_id : BIGINT <<FK>>
    watts : DECIMAL(10,2)
    recorded_at : DATETIME
    created_at : DATETIME
}

entity "alert" as alert {
    * id : BIGINT <<PK>>
    --
    user_id : BIGINT <<FK>>
    device_id : BIGINT <<FK>>
    title : VARCHAR(150)
    message : VARCHAR(500)
    level : VARCHAR(30)
    read : BOOLEAN
    created_at : DATETIME
}

entity "plan" as plan {
    * id : BIGINT <<PK>>
    --
    code : VARCHAR(50) <<UNIQUE>>
    name : VARCHAR(100)
    monthly_price : DECIMAL(10,2)
    description : VARCHAR(255)
    created_at : DATETIME
    updated_at : DATETIME
}

entity "plan_feature" as plan_feature {
    * id : BIGINT <<PK>>
    --
    plan_id : BIGINT <<FK>>
    feature : VARCHAR(255)
}

entity "subscription" as subscription {
    * id : BIGINT <<PK>>
    --
    user_id : BIGINT <<FK>>
    plan_id : BIGINT <<FK>>
    status : VARCHAR(30)
    started_at : DATE
    ends_at : DATE
    created_at : DATETIME
    updated_at : DATETIME
}

' Relationships

user ||--o{ user_access_profile : has
access_profile ||--o{ user_access_profile : assigned_to

access_profile ||--o{ access_profile_permission : contains
permission ||--o{ access_profile_permission : included_in

user ||--o{ device : owns
user ||--o{ routine : creates
device ||--o{ routine : scheduled_by

device ||--o{ energy_reading : generates

user ||--o{ alert : receives
device ||--o{ alert : triggers

plan ||--o{ plan_feature : includes
user ||--o{ subscription : subscribes
plan ||--o{ subscription : selected_in

@enduml