@startuml
title ElectroCorp - Diagrama de clases Frontend

class App {
  - devices: Device[]
  - energyReadings: EnergyReading[]
  - alertsCache: Alert[]
  - currentLang: string
  - currentTheme: string
  + init()
  + loadDevices()
  + loadEnergyReadings()
  + loadAlerts()
  + renderAllLinkedSections()
}

class AuthModule {
  - currentUser: User
  + login(email, password)
  + logout()
  + requireAuth()
  + getCurrentUser()
}

class I18nModule {
  - translations: object
  - currentLang: string
  + loadI18n(lang)
  + applyTranslations()
  + setLanguage(lang)
  + t(key)
}

class ApiClient {
  - baseUrl: string
  + fetchDevices()
  + createDevice(name, type)
  + renameDevice(id, name)
  + deleteDevice(id)
  + turnDeviceOn(id)
  + turnDeviceOff(id)
  + scheduleDevice(id, time, turnOn)
  + fetchEnergyReadings()
  + createEnergyReading(deviceId, amount)
  + fetchAlerts()
  + fetchRecommendations()
}

class ChartModule {
  + buildCharts()
  + addPointToLineChart(value)
  + recalcAnalitica()
  + recalcCentroStats()
  + recalcBarChart()
}

class ModalModule {
  + openConsumptionModal()
  + closeConsumptionModal(save)
  + openDeviceModal()
  + closeDeviceModal(save)
  + openRoutineModal()
  + closeRoutineModal(save)
}

class DashboardView {
  + render()
}

class AnalyticsView {
  + render()
}

class DevicesView {
  + render()
  + toggleDevice(id)
  + renameDevicePrompt(id)
  + deleteDevice(id)
}

class RoutinesView {
  + render()
  + createRoutineFromModal()
}

class RealtimeView {
  + render()
}

class ReportsView {
  + render()
}

class NotificationsView {
  + render()
}

class HistoryView {
  + render()
}

class InsightsView {
  + render()
}

class ActivityView {
  + render()
}

class AccountView {
  + render()
}

class Device {
  + id: string
  + name: string
  + code: string
  + type: string
  + active: boolean
  + ownerId: string
  + currentConsumption: number
  + monthlyConsumption: number
  + schedules: Routine[]
}

class Routine {
  + executeAt: string
  + turnOn: boolean
}

class EnergyReading {
  + id: string
  + deviceId: string
  + amount: number
  + recordedAt: string
}

class Alert {
  + id: string
  + message: string
}

class User {
  + id: string
  + fullName: string
  + email: string
  + status: string
}

App --> AuthModule
App --> I18nModule
App --> ApiClient
App --> ChartModule
App --> ModalModule

App --> DashboardView
App --> AnalyticsView
App --> DevicesView
App --> RoutinesView
App --> RealtimeView
App --> ReportsView
App --> NotificationsView
App --> HistoryView
App --> InsightsView
App --> ActivityView
App --> AccountView

DevicesView --> Device
RoutinesView --> Routine
HistoryView --> EnergyReading
InsightsView --> Alert
AccountView --> User

ApiClient --> Device
ApiClient --> EnergyReading
ApiClient --> Alert

Device "1" *-- "0..*" Routine
User "1" --> "0..*" Device
EnergyReading --> Device

@enduml