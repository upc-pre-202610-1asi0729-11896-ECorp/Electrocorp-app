DeviceJpaEntity "1" -- "0..*" EnergyReadingJpaEntity
DeviceJpaEntity "1" -- "0..*" AlertJpaEntity

PlanJpaEntity "1" -- "0..*" PlanFeatureJpaEntity
PlanJpaEntity "1" -- "0..*" SubscriptionJpaEntity

@enduml