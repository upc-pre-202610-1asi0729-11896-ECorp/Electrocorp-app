AccessProfileRepository <|.. AccessProfilePersistenceAdapter
DeviceRepository <|.. DevicePersistenceAdapter
RoutineRepository <|.. RoutinePersistenceAdapter
EnergyReadingRepository <|.. EnergyReadingPersistenceAdapter
AlertRepository <|.. AlertPersistenceAdapter
PlanRepository <|.. PlanPersistenceAdapter
SubscriptionRepository <|.. SubscriptionPersistenceAdapter

UserPersistenceAdapter --> JpaUserRepository
UserPersistenceAdapter --> UserMapper
UserPersistenceAdapter --> UserJpaEntity

AccessProfilePersistenceAdapter --> JpaAccessProfileRepository
AccessProfilePersistenceAdapter --> AccessProfileMapper
AccessProfilePersistenceAdapter --> AccessProfileJpaEntity

DevicePersistenceAdapter --> JpaDeviceRepository
DevicePersistenceAdapter --> DeviceMapper
DevicePersistenceAdapter --> DeviceJpaEntity

RoutinePersistenceAdapter --> JpaRoutineRepository
RoutinePersistenceAdapter --> RoutineMapper
RoutinePersistenceAdapter --> RoutineJpaEntity

EnergyReadingPersistenceAdapter --> JpaEnergyReadingRepository
EnergyReadingPersistenceAdapter --> EnergyReadingMapper
EnergyReadingPersistenceAdapter --> EnergyReadingJpaEntity

AlertPersistenceAdapter --> JpaAlertRepository
AlertPersistenceAdapter --> AlertMapper
AlertPersistenceAdapter --> AlertJpaEntity

PlanPersistenceAdapter --> JpaPlanRepository
PlanPersistenceAdapter --> PlanMapper
PlanPersistenceAdapter --> PlanJpaEntity

SubscriptionPersistenceAdapter --> JpaSubscriptionRepository
SubscriptionPersistenceAdapter --> SubscriptionMapper
SubscriptionPersistenceAdapter --> SubscriptionJpaEntity

