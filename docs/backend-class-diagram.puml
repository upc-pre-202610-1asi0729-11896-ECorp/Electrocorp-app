@startuml
title ElectroCorp - Backend Class Diagram Updated

skinparam packageStyle rectangle
skinparam classAttributeIconSize 0

package "Shared Kernel" {
  abstract class BaseEntity {
    +id: Long
  }

  abstract class AuditableEntity {
    +createdAt: LocalDateTime
    +updatedAt: LocalDateTime
  }

  interface BaseRepository<T, ID> {
    +findAll(): List<T>
    +findById(id: ID): Optional<T>
    +save(entity: T): T
    +deleteById(id: ID): void
  }

  interface BaseAssembler<TEntity, TResource, TRequest> {
    +toResource(entity: TEntity): TResource
    +toEntity(request: TRequest): TEntity
  }

  class ApiResponse<T> {
    +success: boolean
    +message: String
    +data: T
  }
}

package "IAM" {
  class User {
    +id: Long
    +fullName: String
    +email: String
    +password: String
    +status: String
  }

  class AccessProfile {
    +id: Long
    +name: String
  }

  class UserAccessProfile {
    +userId: Long
    +accessProfileId: Long
  }

  class SignInRequest {
    +email: String
    +password: String
  }

  class SignUpRequest {
    +fullName: String
    +email: String
    +password: String
  }

  class UserResource {
    +id: Long
    +fullName: String
    +email: String
    +status: String
  }

  class AccessProfileResource {
    +id: Long
    +name: String
  }

  class AuthResource {
    +user: UserResource
    +accessProfiles: List<AccessProfileResource>
  }

  interface UserRepository {
    +findByEmail(email: String): Optional<User>
    +existsByEmail(email: String): boolean
  }

  interface AccessProfileRepository {
    +findByName(name: String): Optional<AccessProfile>
  }

  interface UserAccessProfileRepository {
    +findByUserId(userId: Long): List<UserAccessProfile>
  }

  class UserJpaRepository
  class AccessProfileJpaRepository
  class UserAccessProfileJpaRepository

  class UserAssembler
  class AccessProfileAssembler
  class AuthAssembler

  class IamDomainService {
    +isValidEmail(email: String): boolean
    +isAllowedEmailProvider(email: String): boolean
    +isValidPassword(password: String): boolean
  }

  class IamApplicationService {
    +signIn(request: SignInRequest): AuthResource
    +signUp(request: SignUpRequest): AuthResource
    +restoreSession(email: String): AuthResource
  }

  class IamController {
    +signIn(request: SignInRequest): ApiResponse<AuthResource>
    +signUp(request: SignUpRequest): ApiResponse<AuthResource>
    +restoreSession(email: String): ApiResponse<AuthResource>
  }
}

package "Billing" {
  class Plan {
    +id: Long
    +code: String
    +name: String
    +monthlyPrice: BigDecimal
    +description: String
    +status: String
  }

  class Subscription {
    +id: Long
    +userId: Long
    +planId: Long
    +status: String
    +startedAt: LocalDate
    +endsAt: LocalDate
    +isActive(): boolean
  }

  class Payment {
    +id: Long
    +userId: Long
    +planId: Long
    +subscriptionId: Long
    +amount: BigDecimal
    +method: String
    +status: String
    +createdAt: LocalDate
    +cardLastFourDigits: String
    +holderName: String
  }

  class SubscribeRequest {
    +userId: Long
    +planCode: String
  }

  class CancelSubscriptionRequest {
    +subscriptionId: Long
  }

  class ProcessPaymentRequest {
    +userId: Long
    +planCode: String
    +amount: BigDecimal
    +holderName: String
    +cardNumber: String
    +expirationDate: String
    +cvv: String
  }

  class PlanResource
  class SubscriptionResource
  class PaymentResource

  interface PlanRepository {
    +findByCode(code: String): Optional<Plan>
  }

  interface SubscriptionRepository {
    +findByUserIdAndStatus(userId: Long, status: String): List<Subscription>
  }

  interface PaymentRepository {
    +findByUserId(userId: Long): List<Payment>
  }

  class PlanJpaRepository
  class SubscriptionJpaRepository
  class PaymentJpaRepository

  class PlanAssembler
  class SubscriptionAssembler
  class PaymentAssembler

  class SubscriptionPolicyService {
    +canSubscribeToPlan(current: Subscription, targetPlanCode: String): boolean
    +canCancelSubscription(subscription: Subscription): boolean
  }

  class PlanPermissionService {
    +canCreateDevice(planCode: String, currentDevices: int): boolean
    +canCreateRoutine(planCode: String, currentRoutines: int): boolean
    +canCreateManualAlert(planCode: String, currentAlerts: int): boolean
    +canExportCsv(planCode: String): boolean
    +canAccessEnergyHistory(planCode: String): boolean
  }

  class PaymentDomainService {
    +validateCardNumber(cardNumber: String): boolean
    +validateCvv(cvv: String): boolean
    +extractLastFourDigits(cardNumber: String): String
  }

  class BillingApplicationService {
    +getPlans(): List<PlanResource>
    +getActiveSubscriptionByUser(userId: Long): SubscriptionResource
    +getLastPaymentByUser(userId: Long): PaymentResource
    +processPayment(request: ProcessPaymentRequest): PaymentResource
    +subscribe(request: SubscribeRequest): SubscriptionResource
    +cancelSubscription(request: CancelSubscriptionRequest): SubscriptionResource
  }

  class BillingController {
    +getPlans(): ApiResponse<List<PlanResource>>
    +getActiveSubscription(userId: Long): ApiResponse<SubscriptionResource>
    +getPaymentsByUser(userId: Long): ApiResponse<List<PaymentResource>>
    +processPayment(request: ProcessPaymentRequest): ApiResponse<PaymentResource>
    +subscribe(request: SubscribeRequest): ApiResponse<SubscriptionResource>
    +cancelSubscription(request: CancelSubscriptionRequest): ApiResponse<SubscriptionResource>
  }
}

package "Device Control" {
  class Device {
    +id: Long
    +userId: Long
    +name: String
    +type: String
    +room: String
    +powerWatts: Integer
    +status: String
  }

  class Routine {
    +id: Long
    +userId: Long
    +deviceId: Long
    +name: String
    +action: String
    +scheduledTime: String
    +enabled: boolean
  }

  class CreateDeviceRequest {
    +userId: Long
    +name: String
    +type: String
    +room: String
    +powerWatts: Integer
  }

  class CreateRoutineRequest {
    +userId: Long
    +deviceId: Long
    +name: String
    +action: String
    +scheduledTime: String
  }

  class UpdateDeviceStatusRequest {
    +deviceId: Long
    +status: String
  }

  class DeviceResource
  class RoutineResource

  interface DeviceRepository {
    +findByUserId(userId: Long): List<Device>
  }

  interface RoutineRepository {
    +findByUserId(userId: Long): List<Routine>
    +findByDeviceId(deviceId: Long): List<Routine>
  }

  class DeviceJpaRepository
  class RoutineJpaRepository

  class DeviceAssembler
  class RoutineAssembler

  class RoutineConflictCheckerService {
    +hasConflict(candidate: Routine, routines: List<Routine>): boolean
  }

  class DeviceControlApplicationService {
    +getDevicesByUser(userId: Long): List<DeviceResource>
    +createDevice(request: CreateDeviceRequest): DeviceResource
    +updateDeviceStatus(request: UpdateDeviceStatusRequest): DeviceResource
    +deleteDevice(deviceId: Long): void
    +getRoutinesByUser(userId: Long): List<RoutineResource>
    +createRoutine(request: CreateRoutineRequest): RoutineResource
    +toggleRoutine(routineId: Long): RoutineResource
    +deleteRoutine(routineId: Long): void
  }

  class DeviceControlController {
    +getDevicesByUser(userId: Long): ApiResponse<List<DeviceResource>>
    +createDevice(request: CreateDeviceRequest): ApiResponse<DeviceResource>
    +updateDeviceStatus(request: UpdateDeviceStatusRequest): ApiResponse<DeviceResource>
    +deleteDevice(deviceId: Long): ApiResponse<Void>
    +getRoutinesByUser(userId: Long): ApiResponse<List<RoutineResource>>
    +createRoutine(request: CreateRoutineRequest): ApiResponse<RoutineResource>
    +toggleRoutine(routineId: Long): ApiResponse<RoutineResource>
    +deleteRoutine(routineId: Long): ApiResponse<Void>
  }
}

package "Energy Monitoring" {
  class EnergyReading {
    +id: Long
    +userId: Long
    +deviceId: Long
    +deviceName: String
    +watts: BigDecimal
    +recordedAt: LocalDate
    +status: String
  }

  class FilterReadingsRequest {
    +userId: Long
    +startDate: LocalDate
    +endDate: LocalDate
  }

  class CreateEnergyReadingRequest {
    +userId: Long
    +deviceId: Long
    +watts: BigDecimal
    +recordedAt: LocalDate
    +status: String
  }

  class EnergyReadingResource

  interface EnergyReadingRepository {
    +findByUserId(userId: Long): List<EnergyReading>
    +findByUserIdAndRecordedAtBetween(userId: Long, startDate: LocalDate, endDate: LocalDate): List<EnergyReading>
  }

  class EnergyReadingJpaRepository
  class EnergyReadingAssembler

  class EnergyRecommendationService {
    +generateRecommendation(readings: List<EnergyReading>): String
  }

  class EnergyMonitoringApplicationService {
    +getReadingsByUser(userId: Long): List<EnergyReadingResource>
    +filterReadings(request: FilterReadingsRequest): List<EnergyReadingResource>
    +createReading(request: CreateEnergyReadingRequest): EnergyReadingResource
    +exportCsv(userId: Long): byte[]
    +getRecommendation(userId: Long): String
  }

  class EnergyMonitoringController {
    +getReadingsByUser(userId: Long): ApiResponse<List<EnergyReadingResource>>
    +filterReadings(request: FilterReadingsRequest): ApiResponse<List<EnergyReadingResource>>
    +createReading(request: CreateEnergyReadingRequest): ApiResponse<EnergyReadingResource>
    +exportCsv(userId: Long): byte[]
    +getRecommendation(userId: Long): ApiResponse<String>
  }
}

package "Notifications" {
  class Alert {
    +id: Long
    +userId: Long
    +deviceId: Long
    +title: String
    +message: String
    +level: String
    +createdAt: LocalDate
    +read: boolean
  }

  class CreateAlertRequest {
    +userId: Long
    +deviceId: Long
    +title: String
    +message: String
    +level: String
  }

  class MarkAlertAsReadRequest {
    +alertId: Long
  }

  class AlertResource

  interface AlertRepository {
    +findByUserId(userId: Long): List<Alert>
  }

  class AlertJpaRepository
  class AlertAssembler

  class AlertPriorityService {
    +sortByPriorityAndDate(alerts: List<Alert>): List<Alert>
  }

  class NotificationsApplicationService {
    +getAlertsByUser(userId: Long): List<AlertResource>
    +createAlert(request: CreateAlertRequest): AlertResource
    +markAsRead(request: MarkAlertAsReadRequest): AlertResource
    +deleteAlert(alertId: Long): void
  }

  class NotificationsController {
    +getAlertsByUser(userId: Long): ApiResponse<List<AlertResource>>
    +createAlert(request: CreateAlertRequest): ApiResponse<AlertResource>
    +markAsRead(request: MarkAlertAsReadRequest): ApiResponse<AlertResource>
    +deleteAlert(alertId: Long): ApiResponse<Void>
  }
