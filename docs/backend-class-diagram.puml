AccessProfileMapper --> AccessProfileResponse

DeviceMapper --> Device
DeviceMapper --> DeviceJpaEntity
DeviceMapper --> DeviceResponse

RoutineMapper --> Routine
RoutineMapper --> RoutineJpaEntity
RoutineMapper --> RoutineResponse

EnergyReadingMapper --> EnergyReading
EnergyReadingMapper --> EnergyReadingJpaEntity
EnergyReadingMapper --> EnergyReadingResponse

AlertMapper --> Alert
AlertMapper --> AlertJpaEntity
AlertMapper --> AlertResponse

PlanMapper --> Plan
PlanMapper --> PlanJpaEntity
PlanMapper --> PlanResponse

