AuthController --> SignUpRequest
AuthController --> AuthResponse

UserController --> UserApplicationService
UserController --> UserResponse

AccessProfileController --> AccessProfileApplicationService
AccessProfileController --> AccessProfileResponse

DeviceController --> DeviceApplicationService
DeviceController --> CreateDeviceRequest
DeviceController --> UpdateDeviceStatusRequest
DeviceController --> DeviceResponse

RoutineController --> RoutineApplicationService
RoutineController --> CreateRoutineRequest
RoutineController --> UpdateRoutineEnabledRequest
RoutineController --> RoutineResponse

EnergyReadingController --> EnergyMonitoringApplicationService
