@startuml
title ElectroCorp - Frontend Class Diagram Fully Connected

skinparam packageStyle rectangle
skinparam classAttributeIconSize 0
skinparam linetype ortho

' =========================================================
' SHARED
' =========================================================

package "Shared" {
  class App {
    +ngOnInit(): void
    -updatePageTitle(): void
  }

  class AppRouter {
    +routes: Routes
    +navigate(path: string): void
  }

  class RouterOutlet {
    +rendersActivePage(): void
  }

  class TitleService {
    +setTitle(title: string): void
  }

  abstract class BaseEntity<TId> {
    -_id: TId
    +id: TId
  }

  interface BaseResource

  interface BaseResponse<TId> {
    +id: TId
  }

  abstract class BaseAssembler<TEntity, TResource, TResponse> {
    +toEntity(response: TResponse): TEntity
    +toResource(entity: TEntity): TResource
  }

  abstract class BaseApiService<TEntity, TResource, TResponse> {
    -apiBaseUrl: string
    -endpointPath: string
    -assembler: BaseAssembler
    +findAll(): Observable<TResponse[]>
    +findById(id: number): Observable<TResponse>
    +create(resource: TResource): Observable<TResponse>
    +update(id: number, resource: Partial<TResource>): Observable<TResponse>
    +delete(id: number): Observable<void>
  }

  class LocalStorageService {
    +getItem(key: string): string
    +setItem(key: string, value: string): void
    +removeItem(key: string): void
    +clear(): void
  }

  class AuthSessionService {
    -authenticatedSignal
    -userIdSignal
    -userEmailSignal
    -userNameSignal
    +isAuthenticated()
    +userId()
    +userEmail()
    +userName()
    +startSession(payload): void
    +closeSession(): void
    +restoreSession(): void
  }

  class ThemeService {
    +applyTheme(isDarkMode: boolean): void
  }

  class UiPreferencesService {
    -languageSignal
    -darkModeSignal
    +language()
    +darkMode()
    +setLanguage(language): void
    +toggleTheme(): void
    +restorePreferences(): void
  }

  class TranslationFacadeService {
    -loadedLanguages
    +initialize(): Promise<void>
    +changeLanguage(language): Promise<void>
  }

  class ActiveSubscriptionGuard {
    +canActivate(): boolean
  }

  class AppLayoutComponent {
    +switchLanguage(language): Promise<void>
    +toggleTheme(): void
    +signOut(): Promise<void>
  }

  class FooterComponent

  class HomePageComponent {
    +ngOnInit(): Promise<void>
  }

  class AboutPageComponent

  class NotFoundPageComponent
}

' =========================================================
' IAM
' =========================================================

package "IAM" {
  class User {
    -_fullName: string
    -_email: string
    -_status: UserStatus
    +fullName: string
    +email: string
    +status: UserStatus
    +isActive: boolean
  }

  class AccessProfile {
    -_name: string
    -_permissions: string[]
    +name: string
    +permissions: string[]
    +hasPermission(permission: string): boolean
  }

  class SignInDto {
    +email: string
    +password: string
  }

  class SignUpDto {
    +fullName: string
    +email: string
    +password: string
  }

  interface SignInResource {
    +email: string
    +password: string
  }

  interface SignUpResource {
    +fullName: string
    +email: string
    +password: string
  }

  interface UserResponse {
    +id: number
    +fullName: string
    +email: string
    +password: string
    +status: UserStatus
  }

  interface AccessProfileResponse {
    +id: number
    +name: string
    +permissions: string[]
  }

  class UserAssembler

  class AccessProfileAssembler

  class IamApiService {
    +signIn(resource: SignInResource): Promise<AuthPayload>
    +signUp(resource: SignUpResource): Promise<AuthPayload>
    +restoreSession(email: string): Promise<AuthPayload>
  }

  class IamFacade {
    -currentUserSignal
    -accessProfilesSignal
    -loadingSignal
    -errorSignal
    +currentUser()
    +accessProfiles()
    +loading()
    +error()
    +isAuthenticated()
    +signIn(payload: SignInDto): Promise<void>
    +signUp(payload: SignUpDto): Promise<void>
    +restoreSession(): Promise<void>
    +signOut(): void
  }

  class LoginPageComponent {
    +email: string
    +password: string
    +handleSubmit(): Promise<void>
  }

  class RegisterPageComponent {
    +fullName: string
    +email: string
    +password: string
    +handleSubmit(): Promise<void>
  }
}

' =========================================================
' BILLING
' =========================================================

package "Billing" {
  class Plan {
    -_code: PlanCode
    -_name: string
    -_monthlyPrice: number
    -_description: string
    -_features: string[]
    +code: PlanCode
    +name: string
    +monthlyPrice: number
    +description: string
    +features: string[]
  }

  class Subscription {
    -_userId: number
    -_planCode: PlanCode
    -_status: SubscriptionStatus
    -_startedAt: string
    -_endsAt: string
    +userId: number
    +planCode: PlanCode
    +status: SubscriptionStatus
    +startedAt: string
    +endsAt: string
    +isActive: boolean
  }

  class Payment {
    -_userId: number
    -_planCode: PlanCode
    -_amount: number
    -_method: PaymentMethod
    -_status: PaymentStatus
    -_createdAt: string
    -_cardLastFourDigits: string
    -_holderName: string
    +isApproved: boolean
  }

  class SubscribeDto {
    +planCode: PlanCode
  }

  class CancelSubscriptionDto {
    +subscriptionId: number
  }

  class ProcessPaymentDto {
    +planCode: PlanCode
    +amount: number
    +holderName: string
    +cardNumber: string
    +expirationDate: string
    +cvv: string
  }

  interface PlanResource
  interface SubscriptionResource
  interface PaymentResource

  interface PlanResponse
  interface SubscriptionResponse
  interface PaymentResponse

  class PlanAssembler

  class SubscriptionAssembler

  class PaymentAssembler

  class PlansApiService

  class SubscriptionsApiService {
    +findActiveByUserId(userId: number): Observable<SubscriptionResponse[]>
    +cancelSubscription(subscriptionId: number): Observable<SubscriptionResponse>
  }

  class PaymentsApiService {
    +findByUserId(userId: number): Observable<PaymentResponse[]>
  }

  class SubscriptionPolicyService {
    +canSubscribeToPlan(currentSubscription: Subscription, targetPlanCode: PlanCode): boolean
    +canCancelSubscription(subscription: Subscription): boolean
  }

  class PlanPermissionService {
    +getPermissions(planCode: PlanCode)
    +canCreateDevice(planCode: PlanCode, currentDevices: number): boolean
    +canCreateRoutine(planCode: PlanCode, currentRoutines: number): boolean
    +canCreateManualAlert(planCode: PlanCode, currentAlerts: number): boolean
    +canExportCsv(planCode: PlanCode): boolean
    +canAccessEnergyHistory(planCode: PlanCode): boolean
  }

  class BillingFacade {
    -plansSignal
    -activeSubscriptionSignal
    -lastPaymentSignal
    -loadingSignal
    -errorSignal
    +plans()
    +activeSubscription()
    +activePlanCode()
    +activePlan()
    +lastPayment()
    +hasActiveSubscription()
    +loadBilling(): Promise<void>
    +loadPlans(): Promise<void>
    +loadActiveSubscription(): Promise<void>
    +loadLastPayment(): Promise<void>
    +processFakePayment(payload: ProcessPaymentDto): Promise<boolean>
    +subscribe(payload: SubscribeDto): Promise<void>
    +cancelSubscription(payload: CancelSubscriptionDto): Promise<void>
    +cancelCurrentSubscription(): Promise<void>
    +clearError(): void
  }

  class PlansPageComponent {
    +selectedPlan
    +ngOnInit(): Promise<void>
    +handleSubscribe(plan: Plan): void
    +handleConfirmPayment(payload: ProcessPaymentDto): Promise<void>
    +handleCancelSubscription(): Promise<void>
  }

  class PlanCardComponent {
    +plan: Plan
    +loading: boolean
    +isCurrentPlan: boolean
    +onSubscribe(): void
  }

  class PaymentFormComponent {
    +plan: Plan
    +holderName: string
    +cardNumber: string
    +expirationDate: string
    +cvv: string
    +onCardNumberChange(value: string): void
    +onExpirationDateChange(value: string): void
    +onCvvChange(value: string): void
    +onConfirm(): void
    +onCancel(): void
  }
}

' =========================================================
' DEVICE CONTROL
' =========================================================

package "Device Control" {
  class Device {
    -_name: string
    -_room: string
    -_type: DeviceType
    -_status: DeviceStatus
    -_powerWatts: number
    +toggleStatus(): void
  }

  class Routine {
    -_name: string
    -_deviceId: number
    -_action: RoutineAction
    -_scheduledTime: string
    -_enabled: boolean
    +toggleEnabled(): void
  }

  class CreateDeviceDto {
    +name: string
    +room: string
    +type: DeviceType
    +powerWatts: number
  }

  class CreateRoutineDto {
    +name: string
    +deviceId: number
    +action: RoutineAction
    +scheduledTime: string
  }

  class UpdateDeviceStatusDto {
    +deviceId: number
    +status: DeviceStatus
  }

  interface DeviceResource
  interface RoutineResource

  interface DeviceResponse
  interface RoutineResponse

  class DeviceAssembler

  class RoutineAssembler

  class DevicesApiService {
    +updateStatus(deviceId: number, status: DeviceStatus): Observable<DeviceResponse>
  }

  class RoutinesApiService {
    +updateEnabled(routineId: number, enabled: boolean): Observable<RoutineResponse>
  }

  class RoutineConflictCheckerService {
    +hasConflict(candidate: Routine, routines: Routine[]): boolean
  }

  class DeviceControlFacade {
    -devicesSignal
    -routinesSignal
    -loadingSignal
    -errorSignal
    +devices()
    +routines()
    +totalDevices()
    +activeDevices()
    +totalCurrentWatts()
    +totalRoutines()
    +enabledRoutines()
    +loadDevices(): Promise<void>
    +loadRoutines(): Promise<void>
    +addDevice(payload: CreateDeviceDto): Promise<void>
    +toggleDevice(deviceId: number): Promise<void>
    +removeDevice(deviceId: number): Promise<void>
    +addRoutine(payload: CreateRoutineDto): Promise<void>
    +toggleRoutine(routineId: number): Promise<void>
    +removeRoutine(routineId: number): Promise<void>
    +getDeviceName(deviceId: number): string
  }

  class DevicesPageComponent

  class RoutinesPageComponent

  class DeviceCardComponent {
    +device: Device
    +onToggle(): void
    +onRemove(): void
  }

  class DeviceListComponent {
    +devices: Device[]
  }

  class RoutineListComponent {
    +routines: Routine[]
    +getDeviceName(deviceId: number): string
  }
}

' =========================================================
' ENERGY MONITORING
' =========================================================

package "Energy Monitoring" {
  class EnergyReading {
    -_deviceName: string
    -_watts: number
    -_recordedAt: string
    -_status: EnergyReadingStatus
    +isHigh: boolean
  }

  class FilterReadingsDto {
    +startDate: string
    +endDate: string
  }

  interface EnergyReadingResource

  interface EnergyReadingResponse

  class EnergyReadingAssembler

  class ReadingsApiService {
    +findAll(): Observable<EnergyReadingResponse[]>
    +findByDateRange(startDate: string, endDate: string): Observable<EnergyReadingResponse[]>
  }

  class EnergyRecommendationService {
    +generateRecommendation(readings: EnergyReading[]): string
  }

  class EnergyMonitoringFacade {
    -allReadingsSignal
    -readingsSignal
    -loadingSignal
    -errorSignal
    +readings()
    +loading()
    +error()
    +totalWatts()
    +averageWatts()
    +highestReading()
    +recommendationKey()
    +loadReadings(): Promise<void>
    +filterReadings(payload: FilterReadingsDto): void
    +resetFilter(): void
    +exportCsv(): Promise<void>
  }

  class EnergyDashboardPageComponent

  class EnergyHistoryPageComponent

  class MetricsCardsComponent {
    +totalWatts: number
    +averageWatts: number
    +highestReading: number
  }

  class UsageChartComponent {
    +readings: EnergyReading[]
    +getBarHeight(watts: number): number
  }
}

' =========================================================
' NOTIFICATIONS
' =========================================================

package "Notifications" {
  class Alert {
    -_title: string
    -_message: string
    -_level: AlertLevel
    -_createdAt: string
    -_read: boolean
    +unread: boolean
    +markAsRead(): void
  }

  class CreateAlertDto {
    +title: string
    +message: string
    +level: AlertLevel
  }

  class MarkAlertAsReadDto {
    +alertId: number
  }

  interface AlertResource

  interface AlertResponse

  class AlertAssembler

  class AlertsApiService {
    +markAsRead(alertId: number): Observable<AlertResponse>
  }

  class AlertPriorityService {
    +sortByPriorityAndDate(alerts: Alert[]): Alert[]
  }

  class NotificationsFacade {
    -alertsSignal
    -loadingSignal
    -errorSignal
    +alerts()
    +loading()
    +error()
    +unreadCount()
    +sortedAlerts()
    +loadAlerts(): Promise<void>
    +createAlert(payload: CreateAlertDto): Promise<void>
    +markAsRead(payload: MarkAlertAsReadDto): Promise<void>
  }

  class AlertsPageComponent

  class AlertListComponent {
    +alerts: Alert[]
  }
}

' =========================================================
' BASE INHERITANCE / IMPLEMENTATION
' =========================================================

BaseEntity <|-- User
BaseEntity <|-- AccessProfile
BaseEntity <|-- Plan
BaseEntity <|-- Subscription
BaseEntity <|-- Payment
BaseEntity <|-- Device
BaseEntity <|-- Routine
BaseEntity <|-- EnergyReading
BaseEntity <|-- Alert

BaseResource <|.. SignInResource
BaseResource <|.. SignUpResource
BaseResource <|.. PlanResource
BaseResource <|.. SubscriptionResource
BaseResource <|.. PaymentResource
BaseResource <|.. DeviceResource
BaseResource <|.. RoutineResource
BaseResource <|.. EnergyReadingResource
BaseResource <|.. AlertResource

BaseResponse <|.. UserResponse
BaseResponse <|.. AccessProfileResponse
BaseResponse <|.. PlanResponse
BaseResponse <|.. SubscriptionResponse
BaseResponse <|.. PaymentResponse
BaseResponse <|.. DeviceResponse
BaseResponse <|.. RoutineResponse
BaseResponse <|.. EnergyReadingResponse
BaseResponse <|.. AlertResponse

BaseAssembler <|-- UserAssembler
BaseAssembler <|-- AccessProfileAssembler
BaseAssembler <|-- PlanAssembler
BaseAssembler <|-- SubscriptionAssembler
BaseAssembler <|-- PaymentAssembler
BaseAssembler <|-- DeviceAssembler
BaseAssembler <|-- RoutineAssembler
BaseAssembler <|-- EnergyReadingAssembler
BaseAssembler <|-- AlertAssembler

BaseApiService <|-- PlansApiService
BaseApiService <|-- SubscriptionsApiService
BaseApiService <|-- PaymentsApiService
BaseApiService <|-- DevicesApiService
BaseApiService <|-- RoutinesApiService
BaseApiService <|-- ReadingsApiService
BaseApiService <|-- AlertsApiService

BaseApiService o-- BaseAssembler : uses
BaseApiService --> BaseResource : sends
BaseApiService --> BaseResponse : receives

' =========================================================
' ROUTING / LAYOUT / PAGE CONNECTIONS
' =========================================================

App --> AppLayoutComponent : bootstraps
App --> AppRouter : listens navigation
App --> TitleService : updates tab title

AppLayoutComponent --> RouterOutlet : contains
AppLayoutComponent --> FooterComponent : renders
AppLayoutComponent --> AuthSessionService : reads session
AppLayoutComponent --> UiPreferencesService : reads preferences
AppLayoutComponent --> TranslationFacadeService : changes language
AppLayoutComponent --> IamFacade : signs out

AppRouter --> RouterOutlet : activates

AppRouter --> LoginPageComponent : route /iam/login
AppRouter --> RegisterPageComponent : route /iam/register
AppRouter --> HomePageComponent : route /home
AppRouter --> AboutPageComponent : route /about
AppRouter --> NotFoundPageComponent : route /**
AppRouter --> PlansPageComponent : route /billing/plans
AppRouter --> DevicesPageComponent : route /device-control/devices
AppRouter --> RoutinesPageComponent : route /device-control/routines
AppRouter --> EnergyDashboardPageComponent : route /energy-monitoring/dashboard
AppRouter --> EnergyHistoryPageComponent : route /energy-monitoring/history
AppRouter --> AlertsPageComponent : route /notifications/alerts

RouterOutlet --> LoginPageComponent : renders
RouterOutlet --> RegisterPageComponent : renders
RouterOutlet --> HomePageComponent : renders
RouterOutlet --> AboutPageComponent : renders
RouterOutlet --> NotFoundPageComponent : renders
RouterOutlet --> PlansPageComponent : renders
RouterOutlet --> DevicesPageComponent : renders
RouterOutlet --> RoutinesPageComponent : renders
RouterOutlet --> EnergyDashboardPageComponent : renders
RouterOutlet --> EnergyHistoryPageComponent : renders
RouterOutlet --> AlertsPageComponent : renders

AboutPageComponent --> TranslationFacadeService : uses translations
AboutPageComponent --> AppLayoutComponent : displayed inside layout

NotFoundPageComponent --> TranslationFacadeService : uses translations
NotFoundPageComponent --> AppLayoutComponent : displayed inside layout

FooterComponent --> TranslationFacadeService : uses translations
FooterComponent --> AppLayoutComponent : displayed inside layout

ActiveSubscriptionGuard --> BillingFacade : verifies subscription
ActiveSubscriptionGuard --> AuthSessionService : identifies user
AppRouter --> ActiveSubscriptionGuard : protects private routes

' =========================================================
' SHARED SERVICE CONNECTIONS
' =========================================================

AuthSessionService --> LocalStorageService : persists session
UiPreferencesService --> LocalStorageService : persists preferences
UiPreferencesService --> ThemeService : applies theme
TranslationFacadeService --> UiPreferencesService : reads selected language

' =========================================================
' IAM CONNECTIONS
' =========================================================

UserAssembler --> User : creates entity
UserAssembler --> UserResponse : maps from response
AccessProfileAssembler --> AccessProfile : creates entity
AccessProfileAssembler --> AccessProfileResponse : maps from response

IamApiService --> SignInResource : sends
IamApiService --> SignUpResource : sends
IamApiService --> UserResponse : receives
IamApiService --> AccessProfileResponse : receives

IamFacade --> IamApiService : authentication API
IamFacade --> UserAssembler : maps user
IamFacade --> AccessProfileAssembler : maps profiles
IamFacade --> AuthSessionService : starts/closes session
IamFacade --> SignInDto : receives login input
IamFacade --> SignUpDto : receives register input
IamFacade --> User : stores current user
IamFacade --> AccessProfile : stores access profiles

LoginPageComponent --> IamFacade : submits credentials
LoginPageComponent --> SignInDto : builds dto

RegisterPageComponent --> IamFacade : submits registration
RegisterPageComponent --> SignUpDto : builds dto

User "1" -- "*" AccessProfile : has profiles

' =========================================================
' BILLING CONNECTIONS
' =========================================================

PlanAssembler --> Plan : creates entity
PlanAssembler --> PlanResource : creates resource
PlanAssembler --> PlanResponse : maps from response

SubscriptionAssembler --> Subscription : creates entity
SubscriptionAssembler --> SubscriptionResource : creates resource
SubscriptionAssembler --> SubscriptionResponse : maps from response

PaymentAssembler --> Payment : creates entity
PaymentAssembler --> PaymentResource : creates resource
PaymentAssembler --> PaymentResponse : maps from response

PlansApiService --> PlanResource : sends
PlansApiService --> PlanResponse : receives
PlansApiService --> PlanAssembler : maps

SubscriptionsApiService --> SubscriptionResource : sends
SubscriptionsApiService --> SubscriptionResponse : receives
SubscriptionsApiService --> SubscriptionAssembler : maps

PaymentsApiService --> PaymentResource : sends
PaymentsApiService --> PaymentResponse : receives
PaymentsApiService --> PaymentAssembler : maps

BillingFacade --> PlansApiService : loads plans
BillingFacade --> SubscriptionsApiService : manages subscriptions
BillingFacade --> PaymentsApiService : registers payments
BillingFacade --> PlanAssembler : maps plans
BillingFacade --> SubscriptionAssembler : maps subscriptions
BillingFacade --> PaymentAssembler : maps payments
BillingFacade --> SubscriptionPolicyService : validates plan changes
BillingFacade --> AuthSessionService : gets current user id
BillingFacade --> SubscribeDto : receives subscription request
BillingFacade --> CancelSubscriptionDto : receives cancellation request
BillingFacade --> ProcessPaymentDto : receives payment request
BillingFacade --> Plan : stores plan list
BillingFacade --> Subscription : stores active subscription
BillingFacade --> Payment : stores last payment

SubscriptionPolicyService --> Subscription : evaluates current state
SubscriptionPolicyService --> Plan : evaluates target plan
PlanPermissionService --> Plan : reads plan code and limits

PlansPageComponent --> BillingFacade : uses billing state/actions
PlansPageComponent --> PlanCardComponent : renders plan cards
PlansPageComponent --> PaymentFormComponent : opens checkout
PlansPageComponent --> Plan : selects plan
PlansPageComponent --> ProcessPaymentDto : receives payment confirmation

PlanCardComponent --> Plan : displays
PlanCardComponent --> PlansPageComponent : emits subscribe event

PaymentFormComponent --> Plan : displays selected plan
PaymentFormComponent --> ProcessPaymentDto : builds dto
PaymentFormComponent --> PlansPageComponent : emits confirm/cancel

User "1" -- "*" Subscription : owns
User "1" -- "*" Payment : makes
Plan "1" -- "*" Subscription : selected by
Plan "1" -- "*" Payment : paid through
Subscription "1" -- "*" Payment : payment history

' =========================================================
' DEVICE CONTROL CONNECTIONS
' =========================================================

DeviceAssembler --> Device : creates entity
DeviceAssembler --> DeviceResource : creates resource
DeviceAssembler --> DeviceResponse : maps from response

RoutineAssembler --> Routine : creates entity
RoutineAssembler --> RoutineResource : creates resource
RoutineAssembler --> RoutineResponse : maps from response

DevicesApiService --> DeviceResource : sends
DevicesApiService --> DeviceResponse : receives
DevicesApiService --> DeviceAssembler : maps

RoutinesApiService --> RoutineResource : sends
RoutinesApiService --> RoutineResponse : receives
RoutinesApiService --> RoutineAssembler : maps

DeviceControlFacade --> DevicesApiService : manages devices
DeviceControlFacade --> RoutinesApiService : manages routines
DeviceControlFacade --> DeviceAssembler : maps devices
DeviceControlFacade --> RoutineAssembler : maps routines
DeviceControlFacade --> RoutineConflictCheckerService : validates routine conflict
DeviceControlFacade --> BillingFacade : reads active plan
DeviceControlFacade --> PlanPermissionService : validates plan limits
DeviceControlFacade --> CreateDeviceDto : receives device creation
DeviceControlFacade --> CreateRoutineDto : receives routine creation
DeviceControlFacade --> UpdateDeviceStatusDto : receives status update
DeviceControlFacade --> Device : stores devices
DeviceControlFacade --> Routine : stores routines

RoutineConflictCheckerService --> Routine : compares routines
PlanPermissionService --> Device : limits quantity
PlanPermissionService --> Routine : limits quantity

DevicesPageComponent --> DeviceControlFacade : uses device state/actions
DevicesPageComponent --> DeviceListComponent : renders list
DevicesPageComponent --> CreateDeviceDto : builds dto

DeviceListComponent --> DeviceCardComponent : renders cards
DeviceListComponent --> Device : receives collection
DeviceCardComponent --> Device : displays
DeviceCardComponent --> DeviceControlFacade : emits toggle/remove indirectly

RoutinesPageComponent --> DeviceControlFacade : uses routine state/actions
RoutinesPageComponent --> RoutineListComponent : renders routines
RoutinesPageComponent --> CreateRoutineDto : builds dto

RoutineListComponent --> Routine : displays
RoutineListComponent --> DeviceControlFacade : resolves device name
RoutineListComponent --> RoutinesPageComponent : emits toggle/remove

User "1" -- "*" Device : owns
User "1" -- "*" Routine : creates
Device "1" -- "*" Routine : scheduled by

' =========================================================
' ENERGY MONITORING CONNECTIONS
' =========================================================

EnergyReadingAssembler --> EnergyReading : creates entity
EnergyReadingAssembler --> EnergyReadingResource : creates resource
EnergyReadingAssembler --> EnergyReadingResponse : maps from response

ReadingsApiService --> EnergyReadingResource : sends
ReadingsApiService --> EnergyReadingResponse : receives
ReadingsApiService --> EnergyReadingAssembler : maps

EnergyMonitoringFacade --> ReadingsApiService : loads readings
EnergyMonitoringFacade --> EnergyReadingAssembler : maps readings
EnergyMonitoringFacade --> EnergyRecommendationService : generates recommendation
EnergyMonitoringFacade --> BillingFacade : reads active plan
EnergyMonitoringFacade --> PlanPermissionService : validates export/history access
EnergyMonitoringFacade --> FilterReadingsDto : receives filter input
EnergyMonitoringFacade --> EnergyReading : stores readings

EnergyRecommendationService --> EnergyReading : analyzes readings
PlanPermissionService --> EnergyReading : limits advanced access

EnergyDashboardPageComponent --> EnergyMonitoringFacade : uses energy state/actions
EnergyDashboardPageComponent --> MetricsCardsComponent : renders metrics
EnergyDashboardPageComponent --> UsageChartComponent : renders chart
EnergyDashboardPageComponent --> FilterReadingsDto : builds filter dto

EnergyHistoryPageComponent --> EnergyMonitoringFacade : uses readings/history
EnergyHistoryPageComponent --> EnergyReading : displays table rows

MetricsCardsComponent --> EnergyMonitoringFacade : receives computed metrics
UsageChartComponent --> EnergyReading : displays chart data

User "1" -- "*" EnergyReading : owns
Device "1" -- "*" EnergyReading : produces

' =========================================================
' NOTIFICATIONS CONNECTIONS
' =========================================================

AlertAssembler --> Alert : creates entity
AlertAssembler --> AlertResource : creates resource
AlertAssembler --> AlertResponse : maps from response

AlertsApiService --> AlertResource : sends
AlertsApiService --> AlertResponse : receives
AlertsApiService --> AlertAssembler : maps

NotificationsFacade --> AlertsApiService : manages alerts
NotificationsFacade --> AlertAssembler : maps alerts
NotificationsFacade --> AlertPriorityService : sorts alerts
NotificationsFacade --> BillingFacade : reads active plan
NotificationsFacade --> PlanPermissionService : validates alert limits
NotificationsFacade --> CreateAlertDto : receives alert creation
NotificationsFacade --> MarkAlertAsReadDto : receives read command
NotificationsFacade --> Alert : stores alerts

AlertPriorityService --> Alert : sorts by level/date
PlanPermissionService --> Alert : limits quantity

AlertsPageComponent --> NotificationsFacade : uses alert state/actions
AlertsPageComponent --> AlertListComponent : renders alert list
AlertsPageComponent --> CreateAlertDto : builds dto
AlertsPageComponent --> MarkAlertAsReadDto : builds dto

AlertListComponent --> Alert : displays
AlertListComponent --> AlertsPageComponent : emits mark-as-read

User "1" -- "*" Alert : receives
Device "0..1" -- "*" Alert : may trigger

' =========================================================
' HOME DASHBOARD AGGREGATION
' =========================================================

HomePageComponent --> DeviceControlFacade : device/routine metrics
HomePageComponent --> EnergyMonitoringFacade : energy metrics
HomePageComponent --> NotificationsFacade : alert metrics
HomePageComponent --> BillingFacade : active plan summary

@enduml
